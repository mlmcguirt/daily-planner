{
  "name": "daily-planner",
  "version": "2.1.0",
  "description": "A printable-style daily planner PWA that syncs across devices (Cloudflare Pages + D1)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/check-bundle.mjs",
    "build:demo": "vite build --mode demo",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "deploy:demo": "node scripts/deploy-demo.mjs",
    "test:e2e": "node tests/e2e.mjs",
    "test:demo": "node tests/demo.mjs",
    "test:migration": "node tests/migration.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlmcguirt/daily-planner.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "preact": "^10.29.7"
  }
}
